# Required application database connection. These credentials are local-only.
DATABASE_URL=postgres://platform:platform_local_only@localhost:5432/security_platform?sslmode=disable

# Redis connection. Use REDIS_TLS=true outside a trusted local network.
REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=platform_local_only
REDIS_DB=0
REDIS_TLS=false

# Reconnaissance stages: s=subfinder, d=dnsx, n=naabu, h=httpx,
# k=katana, g=gau, a=endpoint classification.
RECON_PIPELINE=sdnhkga
RECON_HEADLESS=false
RECON_TIMEOUT=15m
RECON_RATE_LIMIT=75
RECON_CONCURRENCY=20
RECON_PROVIDER_UPDATE=false
CHAOS_KEY=

# Optional full executable paths avoid same-name PATH collisions (especially
# Python HTTPX versus ProjectDiscovery HTTPX on Windows).
SUBFINDER_EXECUTABLE=subfinder
CHAOS_EXECUTABLE=chaos
DNSX_EXECUTABLE=dnsx
NAABU_EXECUTABLE=naabu
HTTPX_EXECUTABLE=httpx
KATANA_EXECUTABLE=katana
GAU_EXECUTABLE=gau
NUCLEI_EXECUTABLE=nuclei

# Reliable Redis Streams worker settings.
WORKER_CONSUMER_GROUP=capability-workers
WORKER_CONSUMER_NAME=
WORKER_POOL_SIZE=4
WORKER_LEASE_TIMEOUT=2m
WORKER_READ_BLOCK=5s
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE=2s

# Safe Nuclei profile. Takeover is not run as a second implicit pass.
NUCLEI_RATE_LIMIT=50
NUCLEI_HOST_CONCURRENCY=10
NUCLEI_TEMPLATE_CONCURRENCY=10
NUCLEI_HEADLESS_CONCURRENCY=2
NUCLEI_TIMEOUT=10m
NUCLEI_SEVERITY=low,medium,high,critical
NUCLEI_INCLUDE_TAGS=cve,exposure,misconfig
NUCLEI_EXCLUDE_TAGS=dos,fuzz,bruteforce,intrusive
# For deterministic diagnostics, point this at a v10.4.3 snapshot containing
# .platform-template-version with the value v10.4.3.
NUCLEI_TEMPLATE_DIR=
NUCLEI_UPDATE_TEMPLATES=false

ARTIFACT_DRIVER=local
ARTIFACT_ROOT=artifacts
POLICY_RATE_LIMIT=50
POLICY_CONCURRENCY=10
POLICY_MAX_PAYLOAD_BYTES=1048576
POLICY_ALLOWED_METHODS=GET,HEAD,OPTIONS
POLICY_FOLLOW_REDIRECTS=false
LOG_LEVEL=info
REDACT_SECRET_NAMES=
